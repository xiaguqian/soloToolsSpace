
{
  "name": "im-client",
  "version": "1.0.0",
  "description": "即时通讯客户端",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "react-scripts start"
  },
  "build": {
    "appId": "com.example.im",
    "productName": "IM Client",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "deb"
    }
  },
  "dependencies": {
    "electron": "^28.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "axios": "^1.6.0",
    "sockjs-client": "^1.6.1",
    "stompjs": "^2.3.3",
    "sqlite3": "^5.1.7",
    "bcryptjs": "^2.4.3",
    "electron-store": "^8.0.0",
    "react-emoji-picker": "^1.0.1",
    "emoji-picker-react": "^4.4.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.0.1",
    "react-scripts": "5.0.1",
    "electron-devtools-installer": "^3.2.0"
  },
  "homepage": "./",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
