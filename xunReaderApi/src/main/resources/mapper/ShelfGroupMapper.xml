<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xunreader.mapper.ShelfGroupMapper">
    <select id="selectByUserId" resultType="com.xunreader.entity.ShelfGroup">
        SELECT * FROM shelf_groups WHERE user_id = #{userId} ORDER BY is_default DESC, created_at DESC
    </select>
</mapper>