<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xunreader.mapper.ReadingHistoryMapper">
    <select id="selectByUserId" resultType="com.xunreader.entity.ReadingHistory">
        SELECT * FROM reading_history WHERE user_id = #{userId} ORDER BY read_time DESC
    </select>
</mapper>